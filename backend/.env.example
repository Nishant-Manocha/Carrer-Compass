# Copy to .env and fill in values. Never commit .env.

PORT=4000
MONGO_URI=mongodb://127.0.0.1:27017/career_compass

# Comma-separated allowed browser origins (no trailing slashes), e.g. http://localhost:5173
CORS_ORIGIN=http://localhost:5173,http://localhost:8080

# Required for signing JWTs (use a long random string in production)
JWT_SECRET=

# Optional: Gmail (or other SMTP) for OTP and notifications — use an app password, not your account password
EMAIL_USER=
EMAIL_PASS=
